# ============================================================
# ArtéMis MUSE - Streamlit Secrets Example
# Copy this file to .streamlit/secrets.toml and fill in your values.
# このファイルを .streamlit/secrets.toml にコピーして値を入力してください。
# ============================================================

# Notion
# https://www.notion.so/my-integrations
NOTION_API_KEY = "secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NOTION_DB_ID   = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# TMDB (The Movie Database)
# https://www.themoviedb.org/settings/api
TMDB_API_KEY = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Rakuten Books
# https://webservice.rakuten.co.jp/app/list
RAKUTEN_APP_ID       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
RAKUTEN_ACCESS_KEY   = "pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RAKUTEN_AFFILIATE_ID = "xxxxxxxx.xxxxxxxx.xxxxxxxx.xxxxxxxx"  # optional / 任意

# IGDB (Games) — via Twitch Developer
# https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
IGDB_CLIENT_SECRET = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google Drive
# https://console.cloud.google.com/
DRIVE_FOLDER_ID = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

[gcp_service_account]
# Google OAuth2 authorized user credentials
# Googleの認証情報（OAuth2）
type          = "authorized_user"
client_id     = "xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
refresh_token = "1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
